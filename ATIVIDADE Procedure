DELIMITER $$

CREATE PROCEDURE SP_PRO_CUS_P_DATA (
IN SP_PRO_CUS_P_DATA VARCHAR (20)
)
BEGIN
SELECT customers.CustomerName,products.ProductName,customers.City,orders.OrderDate
FROM customers
INNER JOIN orders ON customers.CustomerID = orders.CustomerID
INNER JOIN orderdetails ON orderdetails.ProductID = products.ProductID
INNER JOIN products ON products.ProductID = orderdetails.ProductID
WHERE OrderDate = SP_PRO_CUS_P_DATA;
END $$
DELIMITER ;


CALL SP_PRO_CUS_P_DATA ('1996-07-08');



